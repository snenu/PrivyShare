# Aleo Testnet
NEXT_PUBLIC_ALEO_RPC_URL=https://api.explorer.provable.com/v2
NEXT_PUBLIC_PRIVYSHARE_PROGRAM_ID=privyshare_files_7879.aleo

# Contract deployment (scripts/deploy-contract.sh). Never commit to git.
ALEO_PRIVATE_KEY=your_aleo_private_key

# Pinata/IPFS (server-side upload uses PINATA_JWT; gateway is public)
PINATA_JWT=your_pinata_jwt
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/

# MongoDB (users + file metadata; optional—falls back to localStorage)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/privyshare
